{
  "expo": {
    "name": "Pulse",
    "slug": "pulse",
    "version": "1.0.0",
    "scheme": "pulse",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.pulse.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pulse uses your location to show you what's hot nearby.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Pulse uses your background location to keep the heatmap live.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.pulse.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "818ef116-1a4e-4b5f-bb88-db2f3bc80a68"
      }
    }
  }
}
